{
  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "provider_chain": "deepseek,gemini",
    "provider_models": {
      "deepseek": "deepseek-v4-flash",
      "gemini": "gemini-3.5-flash"
    },
    "model": "deepseek-v4-flash",
    "base_url": "https://api.deepseek.com",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.2,
    "max_tokens": 4096,
    "throttle_sec": 4.5,
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1,
    "languages": ["zh"],
    "curation_focus": "Only prioritize actionable ecommerce operations and AI-enabled ecommerce developments: marketplace policy, fee, permission, or risk-control changes; traffic acquisition, content, advertising, conversion, retention, merchandising, pricing, inventory, fulfillment, returns, customer service, and cross-border operations; and AI tools or cases with concrete workflows, metrics, limitations, or merchant impact. Score generic corporate news, stock or funding news, generic AI news, consumer shopping tips, sponsored promotion, thin trend pieces, and unsupported growth claims below 7.5. Prefer official platform sources, reproducible methods, and evidence with a clear operator action or KPI."
  },
  "sources": {
    "github": [],
    "hackernews": {
      "enabled": false,
      "fetch_top_stories": 0,
      "min_score": 100
    },
    "rss": [
      {
        "name": "Shopify Changelog",
        "url": "https://changelog.shopify.com/feed",
        "enabled": true,
        "category": "ecommerce-platform"
      },
      {
        "name": "Shopify Developer Changelog",
        "url": "https://shopify.dev/changelog/feed.xml",
        "enabled": true,
        "category": "ecommerce-platform"
      },
      {
        "name": "Google Ads & Commerce",
        "url": "https://blog.google/products/ads-commerce/rss/",
        "enabled": true,
        "category": "ecommerce-growth"
      },
      {
        "name": "Google Search Central",
        "url": "https://developers.google.com/search/blog/feed.xml",
        "enabled": true,
        "category": "ecommerce-growth"
      },
      {
        "name": "WooCommerce Developer",
        "url": "https://developer.woocommerce.com/feed/",
        "enabled": true,
        "category": "ecommerce-platform"
      },
      {
        "name": "Practical Ecommerce",
        "url": "https://www.practicalecommerce.com/feed",
        "enabled": true,
        "category": "ecommerce-operations"
      },
      {
        "name": "中国电商平台与政策",
        "url": "https://news.google.com/rss/search?q=%28%E6%B7%98%E5%AE%9D+OR+%E5%A4%A9%E7%8C%AB+OR+%E4%BA%AC%E4%B8%9C+OR+%E6%8A%96%E9%9F%B3%E7%94%B5%E5%95%86+OR+%E5%B0%8F%E7%BA%A2%E4%B9%A6+OR+%E6%8B%BC%E5%A4%9A%E5%A4%9A%29+%28%E5%95%86%E5%AE%B6+OR+%E8%A7%84%E5%88%99+OR+%E6%94%BF%E7%AD%96+OR+%E8%B4%B9%E7%8E%87+OR+%E8%BF%90%E8%90%A5%29+-%E8%82%A1%E7%A5%A8+-%E8%82%A1%E4%BB%B7+-%E8%B4%A2%E6%8A%A5+-%E4%B8%9A%E7%BB%A9+-%E8%9E%8D%E8%B5%84+-%E8%AF%81%E5%88%B8&hl=zh-CN&gl=CN&ceid=CN%3Azh-Hans",
        "enabled": true,
        "category": "ecommerce-platform"
      },
      {
        "name": "社交与直播电商",
        "url": "https://news.google.com/rss/search?q=%28%22social+commerce%22+OR+%22live+shopping%22+OR+%22TikTok+Shop%22%29+%28seller+OR+merchant+OR+conversion+OR+policy%29&hl=en-US&gl=US&ceid=US%3Aen",
        "enabled": true,
        "category": "social-commerce"
      }
    ],
    "reddit": {
      "enabled": false,
      "subreddits": [],
      "users": [],
      "fetch_comments": 0
    },
    "telegram": {
      "enabled": false,
      "channels": []
    },
    "ossinsight": {
      "enabled": false,
      "keywords": []
    },
    "google_news": {
      "enabled": true,
      "query": "(\"AI ecommerce\" OR \"AI e-commerce\" OR \"agentic commerce\" OR \"AI shopping agent\" OR \"AI retail operations\") (merchant OR seller OR conversion OR advertising OR fulfillment OR automation OR checkout) -stock -shares -earnings -lawsuit -funding -scam -fraud -credit -consumer",
      "language": "en-US",
      "country": "US",
      "ceid": "US:en",
      "max_results": 10,
      "category": "ai-commerce"
    }
  },
  "filtering": {
    "ai_score_threshold": 7.5,
    "time_window_hours": 24,
    "max_items": 8,
    "category_groups": {
      "platform": {
        "name": "平台规则与行业动态",
        "limit": 2,
        "categories": ["ecommerce-platform"]
      },
      "growth": {
        "name": "流量、投放与转化",
        "limit": 2,
        "categories": ["ecommerce-growth"]
      },
      "social": {
        "name": "内容、直播与社交电商",
        "limit": 1,
        "categories": ["social-commerce"]
      },
      "operations": {
        "name": "运营方法、商品与履约",
        "limit": 2,
        "categories": ["ecommerce-operations"]
      },
      "ai_tools": {
        "name": "AI 电商工具与自动化",
        "limit": 2,
        "categories": ["ai-commerce"]
      }
    },
    "default_group": "other",
    "default_group_limit": 1
  }
}
